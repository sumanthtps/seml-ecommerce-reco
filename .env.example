# Copy to .env and adjust. All variables are optional; defaults suit local dev.
# The two services use distinct prefixes so they can be configured independently.

# ----- API Gateway (GATEWAY_*) -------------------------------------------- #
# Bearer token clients must present. CHANGE THIS outside local development.
GATEWAY_AUTH_TOKEN=seml-demo-token
# URL of the internal recommendation service.
GATEWAY_RECO_SERVICE_URL=http://127.0.0.1:8001
# Minimum seconds between two requests sharing a rate-limit key.
GATEWAY_RATE_LIMIT_SECONDS=0.25
GATEWAY_REQUEST_TIMEOUT_SECONDS=5.0
GATEWAY_LOG_LEVEL=INFO
GATEWAY_LOG_FORMAT=json
GATEWAY_ENVIRONMENT=local

# ----- Recommendation service (RECO_*) ------------------------------------ #
# Seed the in-memory feature store with synthetic demo data on startup.
RECO_SEED_DEMO_DATA=true
RECO_CONSUMER_POLL_TIMEOUT=0.2
RECO_LOG_LEVEL=INFO
RECO_LOG_FORMAT=json
RECO_ENVIRONMENT=local
